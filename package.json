{
	"name": "n8n-nodes-appreviewbot",
	"version": "0.2.0",
	"description": "n8n community node for AppReviewBot — fetch Apple App Store and Google Play reviews",
	"license": "MIT",
	"homepage": "https://appreviewbot.com",
	"keywords": [
		"n8n-community-node-package",
		"app reviews",
		"app store",
		"google play",
		"appreviewbot",
		"apple app store",
		"review monitoring"
	],
	"author": {
		"name": "AppReviewBot",
		"email": "support@appreviewbot.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/AppReviewBot/n8n-nodes-appreviewbot.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/AppReviewBotApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/AppReviewBot/AppReviewBot.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.29.0",
		"n8n-workflow": "2.16.0",
		"prettier": "3.8.3",
		"release-it": "20.2.0",
		"typescript": "5.9.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
